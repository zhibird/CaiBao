APP_NAME=CaiBao
APP_VERSION=0.26.0
APP_ENV=dev
DB_LEGACY_INIT_ENABLED=true
API_PREFIX=/api/v1
POSTGRES_DB=caibao
POSTGRES_USER=caibao
POSTGRES_PASSWORD=caibao
# SQLite is the default for host-local uvicorn development.
# Docker Compose overrides the container runtime to PostgreSQL automatically.
DATABASE_URL=sqlite:///./CaiBao.db
# Example local PostgreSQL connection string:
# DATABASE_URL=postgresql+psycopg://caibao:caibao@localhost:5432/caibao
AUTH_JWT_SECRET=change-me-before-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=14
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=lax
AUTH_ACCESS_COOKIE_NAME=caibao_access_token
AUTH_REFRESH_COOKIE_NAME=caibao_refresh_token
DEV_ADMIN_ENABLED=true
DEV_ADMIN_ACCOUNT_ID=dev_admin
DEV_ADMIN_DISPLAY_NAME=Developer Admin
DEV_ADMIN_TOKEN=dev-admin-token

LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MOCK_DIM=256
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=30
# Example override on Windows:
# UPLOAD_ROOT_DIR=C:/Users/your-name/AppData/Local/CaiBao/uploads
UPLOAD_MAX_FILE_SIZE_MB=20

# Optional SQLite backup/debug override for non-Docker local runs:
# DATABASE_URL=sqlite:///C:/Users/your-name/AppData/Local/CaiBao/CaiBao.db
# DB_LEGACY_INIT_ENABLED=true

# --- MCP (Model Context Protocol) ---
# 开启后从 MCP_CONFIG_PATH 读取 stdio 服务器清单，注册为 mcp__{server}__{tool} 工具。
# 相对路径以仓库根目录为基准。详见 README「启用 MCP」。
# MCP_ENABLED=true
# MCP_CONFIG_PATH=config/mcp_servers.json
# MCP_INIT_TIMEOUT_SECONDS=10
# MCP_CALL_TIMEOUT_SECONDS=30
# MCP_MAX_OUTPUT_BYTES=200000

# Optional CLI coding-agent backends (run_mode: claude_code / codex / pi).
# Requires the corresponding CLI installed on the server host.
# 安全提示：CLI 是能执行 shell/文件操作的自主代理。子进程只继承环境变量白名单
# （不含 AUTH_JWT_SECRET / DATABASE_URL / provider key），但 workdir 仅设 cwd 而非
# 读监狱——CLI 可读取宿主机进程可达的任意文件。请勿把 DB/.env 与工作区放在同一可达
# 路径树，且仅对可信团队成员开放；生产多租户场景需自行为每次 run 套 OS 沙箱。详见
# docs/step-13-cli-agent-backends.md 第 6 节。
# CLI_AGENT_ENABLED=true
# CLI_AGENT_WORKSPACE_ROOT=data/cli_agent_workspaces
# CLI_AGENT_TIMEOUT_SECONDS=600
# CLI_AGENT_MAX_STEP_OUTPUT_CHARS=4000
# CLI_AGENT_EXTRA_ENV_JSON={"ANTHROPIC_API_KEY":"sk-..."}
# CLI_AGENT_CLAUDE_PATH=claude
# CLI_AGENT_CLAUDE_MODEL=
# CLI_AGENT_CLAUDE_PERMISSION_MODE=acceptEdits
# CLI_AGENT_CLAUDE_ALLOWED_TOOLS=
# CLI_AGENT_CODEX_PATH=codex
# CLI_AGENT_CODEX_MODEL=
# CLI_AGENT_CODEX_SANDBOX=workspace-write
# CLI_AGENT_PI_PATH=pi
# CLI_AGENT_PI_PROVIDER=anthropic
# CLI_AGENT_PI_MODEL=claude-sonnet-4-5
# CLI_AGENT_PI_THINKING=medium
