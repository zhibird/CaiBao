{
  "servers": [
    {
      "name": "utils",
      "enabled": true,
      "command": ".venv/bin/python",
      "args": ["mcp-servers/utils/server.py"],
      "cwd": ".",
      "timeout_seconds": 20
    },
    {
      "name": "filesystem_demo",
      "enabled": false,
      "command": "node",
      "args": ["./mcp-servers/filesystem/index.js"],
      "cwd": ".",
      "env": {
        "SOME_KEY": "${SOME_KEY}"
      },
      "timeout_seconds": 20,
      "allowed_tools": ["read_file", "list_dir"]
    }
  ]
}
